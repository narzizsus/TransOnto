  <rdf:Description rdf:about="https://w3id.org/transonto#Ambiguity_DE_21">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/transonto#RuleAmbiguity"/>
    <rdfs:label xml:lang="en">DE Ambiguity 21: Final devoicing optional r</rdfs:label>
    <to:ambiguityDescription xml:lang="en">Final coda r after short vowel: drop or retain in Thai? Karl→คาร์ล or คาร์?</to:ambiguityDescription>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/transonto#LexicalEntry">
