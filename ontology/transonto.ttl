        to:RuleAddition ;
    rdfs:label "FR Addition 2"@en,
        "การเพิ่ม FR 2: สระนาสิก 2"@th ;
    to:additionNumber 2 ;
    to:appliedToLanguage to:French .

to:RuleAddition_FR_03 a owl:NamedIndividual,
        to:RuleAddition ;
    rdfs:label "FR Addition 3"@en,
        "การเพิ่ม FR 3: สระนาสิก 3 (ยังไม่แก้ไข)"@th ;
    to:additionNumber 3 ;
    to:appliedToLanguage to:French .

to:RuleAddition_FR_04 a owl:NamedIndividual,
        to:RuleAddition ;
    rdfs:label "FR Addition 4"@en,
        "การเพิ่ม FR 4: กฎ liaison (ยังไม่แก้ไข)"@th ;
    to:additionNumber 4 ;
    to:appliedToLanguage to:French .

to:RuleAddition_FR_05 a owl:NamedIndividual,
        to:RuleAddition ;
    rdfs:label "FR Addition 5"@en,
        "การเพิ่ม FR 5: h aspire กับ h muet"@th ;
    to:additionNumber 5 ;
