@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix to: <https://w3id.org/transonto#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/transonto> a owl:Ontology ;
    dcterms:created "2025-09-01"^^xsd:date ;
    dcterms:creator "NLP & Semantics Technology Team, NECTEC, NSTDA"@en ;
    dcterms:description "An OWL ontology capturing transliteration guidelines, rules, lexical entries, evaluation results, and computational readiness levels for the Royal Society of Thailand transliteration system covering German, French, and English."@en ;
    dcterms:modified "2026-06-14"^^xsd:date ;
    dcterms:title "TransOnto: Transliteration Knowledge Ontology"@en,
        "TransOnto: ออนโทโลยีความรู้การถ่ายอักษร"@th ;
    rdfs:seeAlso <https://github.com/narzizsus/TransOnto> ;
    owl:versionIRI <https://w3id.org/transonto/1.0> ;
    owl:versionInfo "1.0" .

to:Ambiguity_DE_28 a owl:NamedIndividual,
        to:RuleAmbiguity ;
    rdfs:label "DE Ambiguity 28: Hyphen retention"@en ;
    to:ambiguityDescription "When to retain vs omit hyphen in Thai output for compound names."@en .

to:Ambiguity_DE_30 a owl:NamedIndividual,
        to:RuleAmbiguity ;
    rdfs:label "DE Ambiguity 30: Foreign word identification"@en ;
    to:ambiguityDescription "How to identify italicized foreign words programmatically without typographic information."@en .

to:Decision_DE_17a a owl:NamedIndividual,
        to:ExpertDecision ;
    rdfs:label "Decision: Rad final t devoiced"@en ;
    to:decisionJustification "Committee: word-final d in Rad is devoiced to t; render as รัด."@en .

to:Decision_DE_17b a owl:NamedIndividual,
        to:ExpertDecision ;
    rdfs:label "Decision: regional r-variants accepted"@en ;
    to:decisionJustification "Both ร and รา accepted as variants for initial r; prefer ร in formal text."@en .

to:Decision_DE_21a a owl:NamedIndividual,
        to:ExpertDecision ;
    rdfs:label "Decision: final r retained in monosyllables"@en ;
    to:decisionJustification "Monosyllabic words with final r: retain as เออ in Thai."@en .

to:Decision_DE_21b a owl:NamedIndividual,
        to:ExpertDecision ;
    rdfs:label "Decision: Karl coda r"@en ;
    to:decisionJustification "Karl: retain as คาร์ล (not คาล) per common convention."@en .

to:Decision_DE_25a a owl:NamedIndividual,
        to:ExpertDecision ;
    rdfs:label "Decision: French loanword list from Duden"@en ;
    to:decisionJustification "Use Duden Fremdwoerterbuch as reference for French loanword identification."@en .

to:Decision_DE_25b a owl:NamedIndividual,
        to:ExpertDecision ;
    rdfs:label "Decision: Genie as French loanword"@en ;
    to:decisionJustification "Genie confirmed as French loanword; apply French phonology: จีนี."@en .

to:Decision_DE_27a a owl:NamedIndividual,
        to:ExpertDecision ;
    rdfs:label "Decision: von -> ฟอน"@en ;
    to:decisionJustification "von -> ฟอน in standard contexts; ฟ็อน only in careful pronunciation."@en .

to:Decision_DE_27b a owl:NamedIndividual,
        to:ExpertDecision ;
    rdfs:label "Decision: zu -> ซู"@en ;
    to:decisionJustification "zu -> ซู as particle; คู only in name-initial position."@en .

to:Decision_DE_28 a owl:NamedIndividual,
        to:ExpertDecision ;
    rdfs:label "Decision: hyphen retained"@en ;
    to:decisionJustification "Hyphen retained in compound names following German source form."@en .

to:Decision_DE_30 a owl:NamedIndividual,
        to:ExpertDecision ;
    rdfs:label "Decision: italic identification requires metadata"@en ;
    to:decisionJustification "Italic foreign words require text metadata; apply German rules when italic info unavailable."@en .

to:Entry_DE_Frankfurt a owl:NamedIndividual,
        to:LexicalEntry ;
    rdfs:label "Frankfurt am Main"@en ;
    to:exemplifiesRule to:Rule_DE_31 ;
    to:fromSourceLanguage to:German ;
    to:hasThaiForm to:Thai_Frankfurt ;
    to:sourceForm "Frankfurt am Main" .

to:Entry_DE_Mueller a owl:NamedIndividual,
        to:LexicalEntry ;
    rdfs:label "Mueller"@en ;
    to:exemplifiesRule to:Rule_DE_08,
        to:Rule_DE_09 ;
    to:fromSourceLanguage to:German ;
    to:hasThaiForm to:Thai_Mueller_1,
        to:Thai_Mueller_2 ;
    to:ipa "[mYlA, mYlAr]" ;
    to:sourceForm "Mueller" .

to:Entry_DE_Schmidt a owl:NamedIndividual,
        to:LexicalEntry ;
    rdfs:label "Schmidt"@en ;
    to:exemplifiesRule to:Rule_DE_05,
        to:Rule_DE_15 ;
    to:fromSourceLanguage to:German ;
    to:hasThaiForm to:Thai_Schmidt ;
    to:ipa "[Smit]" ;
    to:sourceForm "Schmidt" .

to:Entry_DE_Schulze a owl:NamedIndividual,
        to:LexicalEntry ;
    rdfs:label "Schulze"@en ;
    to:exemplifiesRule to:Rule_DE_15 ;
    to:fromSourceLanguage to:German ;
    to:hasThaiForm to:Thai_Schulze ;
    to:sourceForm "Schulze" .

to:ErrorType_Ambiguity a owl:NamedIndividual,
        to:ErrorType ;
    rdfs:label "Ambiguity Error"@en,
        "ข้อผิดพลาดจากความคลุมเครือ"@th ;
    rdfs:comment "Errors due to underspecified rules where multiple valid Thai forms exist."@en .

to:ErrorType_G2P a owl:NamedIndividual,
        to:ErrorType ;
    rdfs:label "G2P Error"@en,
        "ข้อผิดพลาด G2P"@th ;
    rdfs:comment "Errors arising from incorrect grapheme-to-phoneme conversion before the transliteration rule is applied."@en .

to:ErrorType_ProperNoun a owl:NamedIndividual,
        to:ErrorType ;
    rdfs:label "Proper Noun Error"@en,
        "ข้อผิดพลาดจากชื่อเฉพาะ"@th ;
    rdfs:comment "Errors specific to proper nouns (personal names, place names) not covered by general rules."@en .

to:EvalResult_DE_2025 a owl:NamedIndividual,
        to:EvaluationResult ;
    rdfs:label "DE System Evaluation 2025"@en ;
    rdfs:comment "Accuracy on NECTEC internal benchmark; word-level 92.68%, syllable-level 97.35%, character-level 97.34%. Note: this individual is in the ontology file (transonto.ttl), not instantiated as ABox EvaluationResult in kg_all.ttl."@en ;
    to:accuracyScore 0.9268 ;
    to:characterAccuracy 0.9734 ;
    to:syllableAccuracy 0.9735 .

to:EvalResult_EN_2025 a owl:NamedIndividual,
        to:EvaluationResult ;
    rdfs:label "EN System Evaluation 2025"@en ;
    rdfs:comment "Accuracy on NECTEC internal benchmark; word-level 67.48% (220/326 items)."@en ;
    to:accuracyScore 0.6748 .

to:RuleAddition_FR_01 a owl:NamedIndividual,
        to:RuleAddition ;
    rdfs:label "FR Addition 1"@en,
        "การเพิ่ม FR 1: สระนาสิก"@th ;
    to:additionNumber 1 ;
    to:appliedToLanguage to:French .

