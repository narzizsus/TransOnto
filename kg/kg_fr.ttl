@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix to:   <https://w3id.org/transonto#> .

# ============================================================
# RoyalSocietyTransKG — French KG (kg_fr.ttl)
# Phase 2.2: French lexical entries + benchmark + expert decisions
# Source: readme_fr.html (Royal Society Thai Transliteration, French)
# Generated: 2026-06-13
# Additions 1–14 from Le Petit Robert-based French phonology spec
# ============================================================

<https://w3id.org/transonto/kg/fr>
    a owl:Ontology ;
    owl:imports <https://w3id.org/transonto/1.0> ;
    dcterms:title "RoyalSocietyTransKG — French"@en ;
    dcterms:description "French transliteration knowledge graph with 92 lexical entries, benchmark items, gold labels, and expert decisions. Based on Le Petit Robert, 2006."@en ;
    owl:versionInfo "1.0" .

# ============================================================
# Expert
# ============================================================

to:Expert_RoyalSociety_FR
    a owl:NamedIndividual , to:Expert ;
    rdfs:label "Royal Society of Thailand — French Committee"@en ,
               "คณะกรรมการทับศัพท์ภาษาฝรั่งเศส ราชบัณฑิตยสภา"@th ;
    dcterms:description "Expert committee responsible for adjudicating French transliteration decisions based on Le Petit Robert, 2006."@en .

# ============================================================
# French RuleAddition individuals (FR Add 1–14)
# RuleAddition subClassOf Rule; linked to Guideline_FR
# ============================================================

to:RuleAddition_FR_01
    a owl:NamedIndividual , to:RuleAddition ;
    rdfs:label "FR Addition 1"@en ;
    to:additionNumber "1"^^xsd:integer ;
    to:ruleText "Pronunciation follows standard French (Standard français/Hochfranzösisch). IPA sourced from Le Petit Robert, Dictionnaire de la langue française, 2006. Vowel phoneme [ʃ] → ช, [ʀ] → ร, [ɲ] → น, [y] → ว, [ø]/[ɶ] → เออ."@en ;
    to:appliedToLanguage to:French .

to:RuleAddition_FR_02
    a owl:NamedIndividual , to:RuleAddition ;
    rdfs:label "FR Addition 2"@en ;
    to:additionNumber "2"^^xsd:integer ;
    to:ruleText "IPA notation uses Le Petit Robert conventions including uvular r [ʀ] and French nasal vowels [ɛ̃], [ɑ̃], [ɔ̃], [œ̃]. When two IPA forms are given, both are standard."@en ;
    to:appliedToLanguage to:French .

to:RuleAddition_FR_03
    a owl:NamedIndividual , to:RuleAddition ;
    rdfs:label "FR Addition 3"@en ;
    to:additionNumber "3"^^xsd:integer ;
    to:ruleText "UNRESOLVED: Nasal consonants at word-final position. Committee acknowledged ambiguity in mapping nasalized vowels [ɑ̃]/[ɔ̃] vs consonant-final nasals. Napoléon and champagne illustrate the pattern."@en ;
    to:appliedToLanguage to:French .

to:RuleAddition_FR_04
    a owl:NamedIndividual , to:RuleAddition ;
    rdfs:label "FR Addition 4"@en ;
    to:additionNumber "4"^^xsd:integer ;
    to:ruleText "UNRESOLVED: Silent letters in French orthography interact with Thai transliteration. Words written with final consonants that are phonetically absent require special handling."@en ;
    to:appliedToLanguage to:French .

to:RuleAddition_FR_05
    a owl:NamedIndividual , to:RuleAddition ;
    rdfs:label "FR Addition 5"@en ;
    to:additionNumber "5"^^xsd:integer ;
    to:ruleText "Final consonants p, t, k, s, f are generally silent in French word-final position and not represented in Thai transliteration unless followed by a vowel-initial word (liaison). aide→เอด: final -e is silent; haute→โอต: final position."@en ;
    to:appliedToLanguage to:French .

to:RuleAddition_FR_06
    a owl:NamedIndividual , to:RuleAddition ;
    rdfs:label "FR Addition 6"@en ;
    to:additionNumber "6"^^xsd:integer ;
    to:ruleText "Final consonants b, d, g, z, v, ʒ, l, ʀ, m, n followed by a pause are deleted or reduced. Word-final silent consonant deletion. Applies to common words like chat [ʃa]→ชา, beau [bo]→โบ."@en ;
    to:appliedToLanguage to:French .

to:RuleAddition_FR_07
    a owl:NamedIndividual , to:RuleAddition ;
    rdfs:label "FR Addition 7"@en ;
    to:additionNumber "7"^^xsd:integer ;
    to:ruleText "Mute-e in medial syllable causes consonant cluster in Thai. When e caduc (schwa) is deleted, preceding consonants form a cluster. chopper [ʃɔpe]→ชอปเป shows retention of unstressed syllable."@en ;
    to:appliedToLanguage to:French .

to:RuleAddition_FR_08
    a owl:NamedIndividual , to:RuleAddition ;
    rdfs:label "FR Addition 8"@en ;
    to:additionNumber "8"^^xsd:integer ;
    to:ruleText "Stop consonant clusters pr-, tr-, kr- at word onset. French initial stop+liquid clusters are rendered as Thai consonant clusters or split syllables. 8.1: pr-; 8.2: tr-; 8.3: cr-/kr-."@en ;
    to:appliedToLanguage to:French .

to:RuleAddition_FR_09
    a owl:NamedIndividual , to:RuleAddition ;
    rdfs:label "FR Addition 9"@en ;
    to:additionNumber "9"^^xsd:integer ;
    to:ruleText "Consonant reduction in complex codas and specific clusters. Semi-vowel [j] (yod) from ill/y sequences; lateral clusters; r-consonant patterns. 9.1: yod; 9.2: ill→j/i; 9.3: C+r final; 9.4: r+coda; 9.5: s/x+r."@en ;
    to:appliedToLanguage to:French .

to:RuleAddition_FR_10
    a owl:NamedIndividual , to:RuleAddition ;
    rdfs:label "FR Addition 10"@en ;
    to:additionNumber "10"^^xsd:integer ;
    to:ruleText "Nasal vowels (voyelles nasales). French nasal vowels have no exact Thai equivalent. 10.1: ɛ̃/œ̃→แ_ง; 10.2: ɔ̃→อ็อง, ɑ̃→อ็อง; brun pattern maps [œ̃]→อ็อง."@en ;
    to:appliedToLanguage to:French .

to:RuleAddition_FR_11
    a owl:NamedIndividual , to:RuleAddition ;
    rdfs:label "FR Addition 11"@en ;
    to:additionNumber "11"^^xsd:integer ;
    to:ruleText "Proper nouns follow their phonological pattern. Famous persons use IPA directly. Compound and hyphenated names retain structure with hyphens. Titles (de, le, la) follow liaison rules."@en ;
    to:appliedToLanguage to:French .

to:RuleAddition_FR_12
    a owl:NamedIndividual , to:RuleAddition ;
    rdfs:label "FR Addition 12"@en ;
    to:additionNumber "12"^^xsd:integer ;
    to:ruleText "French alphabet. Each letter name has a fixed Thai rendering independent of its phonological context."@en ;
    to:appliedToLanguage to:French .

to:RuleAddition_FR_13
    a owl:NamedIndividual , to:RuleAddition ;
    rdfs:label "FR Addition 13"@en ;
    to:additionNumber "13"^^xsd:integer ;
    to:ruleText "H mute vs h aspiré distinction. H muet allows liaison and elision (les hommes→lezɔm). H aspiré blocks liaison (le haricot→lə'aʀiko). Committee marks h aspiré entries explicitly."@en ;
    to:appliedToLanguage to:French .

to:RuleAddition_FR_14
    a owl:NamedIndividual , to:RuleAddition ;
    rdfs:label "FR Addition 14"@en ;
    to:additionNumber "14"^^xsd:integer ;
    to:ruleText "Liaison rules. Final consonants normally silent become pronounced when followed by a vowel-initial word. Liaison consonants: s/x→[z], d→[t], t→[t], n→[n], f→[v], r→[r]. Fixed expressions (groupes figés) always apply liaison."@en ;
    to:appliedToLanguage to:French .

# ============================================================
# French RuleAmbiguities
# ============================================================

to:Ambiguity_FR_03
    a owl:NamedIndividual , to:RuleAmbiguity ;
    rdfs:label "Ambiguity FR 03"@en ;
    to:ambiguityDescription "Nasal consonant ambiguity in French proper nouns. Words like Napoléon and champagne have phonological nasality that maps to Thai ง. Committee has not finalized nasal mapping for all environments."@en ;
    to:hasAmbiguity to:RuleAddition_FR_03 .

to:Ambiguity_FR_09
    a owl:NamedIndividual , to:RuleAmbiguity ;
    rdfs:label "Ambiguity FR 09"@en ;
    to:ambiguityDescription "Semi-vowel yod [j] and consonant reduction cluster patterns. fouine [fwinɛ/fwin] shows optional schwa deletion. Yod-initial clusters before nasal vowels remain under review."@en ;
    to:hasAmbiguity to:RuleAddition_FR_09 .

to:Ambiguity_FR_13
    a owl:NamedIndividual , to:RuleAmbiguity ;
    rdfs:label "Ambiguity FR 13"@en ;
    to:ambiguityDescription "H mute vs h aspiré distinction. Phonetically identical word-initial h, but liaison/elision behavior differs. le haricot [lə'aʀiko] vs les hommes [lezɔm] requires lexical lookup."@en ;
    to:hasAmbiguity to:RuleAddition_FR_13 .

# ============================================================
# Expert Decisions (FR)
# ============================================================

to:Decision_FR_03_nasal
    a owl:NamedIndividual , to:ExpertDecision ;
    rdfs:label "Decision FR 03 nasal"@en ;
    to:decisionJustification "Nasal vowel [ɑ̃]/[ɔ̃] renders as อ็อง in open syllable. [ɛ̃]/[œ̃] renders as แ_ง. Proper noun nasals follow standard phonological mapping. champagne→ชองปาน confirmed by committee."@en ;
    to:madeByExpert to:Expert_RoyalSociety_FR .

to:Decision_FR_09_yod
    a owl:NamedIndividual , to:ExpertDecision ;
    rdfs:label "Decision FR 09 yod"@en ;
    to:decisionJustification "Yod [j] from -ille, -ill- renders as ย. When schwa deletion produces consonant cluster, preceding consonant is attached to the previous syllable in Thai rendering."@en ;
    to:madeByExpert to:Expert_RoyalSociety_FR .

to:Decision_FR_13_h
    a owl:NamedIndividual , to:ExpertDecision ;
    rdfs:label "Decision FR 13 h"@en ;
    to:decisionJustification "H aspiré blocks liaison: le haricot→เลอ อาริโก (no linking). H muet allows liaison: les hommes→เลซอม. Committee relies on Le Petit Robert diacritic [ʼ] notation to mark h aspiré."@en ;
    to:madeByExpert to:Expert_RoyalSociety_FR .

to:Ambiguity_FR_03
    to:justifiedByDecision to:Decision_FR_03_nasal .

to:Ambiguity_FR_09
    to:justifiedByDecision to:Decision_FR_09_yod .

to:Ambiguity_FR_13
    to:justifiedByDecision to:Decision_FR_13_h .

