@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix to:   <https://w3id.org/transonto#> .

# ============================================================
# RoyalSocietyTransKG — German KG (kg_de.ttl)
# Phase 2.1: Full German lexical entries + benchmark + expert decisions
# Source: readme_de.html (Royal Society Thai Transliteration, German)
# Generated: 2026-06-13
# ============================================================

<https://w3id.org/transonto/kg/de>
    a owl:Ontology ;
    owl:imports <https://w3id.org/transonto/1.0> ;
    dcterms:title "RoyalSocietyTransKG — German"@en ;
    dcterms:description "German transliteration knowledge graph with 180 lexical entries, benchmark items, gold labels, and expert decisions."@en ;
    owl:versionInfo "1.0" .

# ============================================================
# Expert
# ============================================================

to:Expert_RoyalSociety_DE
    a owl:NamedIndividual , to:Expert ;
    rdfs:label "Royal Society of Thailand — German Committee"@en ,
               "คณะกรรมการทับศัพท์ภาษาเยอรมัน ราชบัณฑิตยสภา"@th ;
    dcterms:description "Expert committee responsible for adjudicating German transliteration decisions."@en .

# ============================================================
# Expert Decisions (extended)
# ============================================================

to:Decision_DE_17_Rad
    a owl:NamedIndividual , to:ExpertDecision ;
    rdfs:label "Decision DE 17 Rad"@en ;
    to:decisionJustification "For Rad and similar VC̄ words where r can be [ʁ], [r], or [ʀ]: use รัท as default; regional variants may use รา."@en ;
    to:madeByExpert to:Expert_RoyalSociety_DE .

to:Decision_DE_21_final_r
    a owl:NamedIndividual , to:ExpertDecision ;
    rdfs:label "Decision DE 21 final r"@en ;
    to:decisionJustification "Final coda r after a short vowel: retain as ร์ in Thai. Karl→คาร์ล. r is not dropped but its syllabic value depends on stress."@en ;
    to:madeByExpert to:Expert_RoyalSociety_DE .

to:Decision_DE_25_loanword
    a owl:NamedIndividual , to:ExpertDecision ;
    rdfs:label "Decision DE 25 loanword"@en ;
    to:decisionJustification "French loanwords in German that retain French phonology are identified by ʒ, ɲ in IPA. Genie, Blammage confirmed as French-phonology items."@en ;
    to:madeByExpert to:Expert_RoyalSociety_DE .

to:Decision_DE_27_von
    a owl:NamedIndividual , to:ExpertDecision ;
    rdfs:label "Decision DE 27 von"@en ;
    to:decisionJustification "von→ฟอน (standard); zu→ซู (standard). No context-dependent variation; committee uses these forms consistently."@en ;
    to:madeByExpert to:Expert_RoyalSociety_DE .

# ============================================================
# Ambiguity → Decision links (additional)
# ============================================================

to:Ambiguity_DE_17
    to:justifiedByDecision to:Decision_DE_17_Rad .

to:Ambiguity_DE_21
    to:justifiedByDecision to:Decision_DE_21_final_r .

to:Ambiguity_DE_25
    to:justifiedByDecision to:Decision_DE_25_loanword .

to:Ambiguity_DE_27
    to:justifiedByDecision to:Decision_DE_27_von .

