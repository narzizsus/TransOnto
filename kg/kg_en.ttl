@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix to:   <https://w3id.org/transonto#> .

# ============================================================
# RoyalSocietyTransKG — English KG (kg_en.ttl)
# Phase 2.3: English benchmark 297 items + evaluation result
# Source: งานงวด 3 (NECTEC report, 2026-04) 326 benchmark items
# Accuracy: word-level 67.48% (220/326)
# English guideline: ราชกิจจานุเบกษา เล่ม 106 ตอน 153 (2532/1989)
# ============================================================

<https://w3id.org/transonto/kg/en>
    a owl:Ontology ;
    owl:imports <https://w3id.org/transonto/1.0> ;
    dcterms:title "RoyalSocietyTransKG — English"@en ;
    dcterms:description "English transliteration benchmark KG with 297 lexical entries, gold labels, and system evaluation. Based on NECTEC benchmark, British English IPA from Cambridge Dictionary."@en ;
    owl:versionInfo "1.0" .

to:Expert_NECTEC_EN
    a owl:NamedIndividual , to:Expert ;
    rdfs:label "NECTEC Natural Language Processing Team"@en ,
               "ทีมวิจัยเทคโนโลยีภาษาธรรมชาติและความหมาย ศูนย์เทคโนโลยีอิเล็กทรอนิกส์และคอมพิวเตอร์แห่งชาติ"@th ;
    dcterms:description "NECTEC research team responsible for developing the English transliteration system and benchmark evaluation (Report 3, April 2026)."@en .

# ============================================================
# English Rule individuals (12 test categories)
# ============================================================

to:Rule_EN_01
    a owl:NamedIndividual , to:Rule ;
    rdfs:label "EN Rule 01"@en ;
    to:ruleNumber "1"^^xsd:integer ;
    to:ruleText "Initial consonants (พยัญชนะต้น): single initial consonants mapped to Thai by IPA. Multiple Thai options exist for same IPA (e.g., /k/ → ค or ก)."@en ;
    to:appliedToLanguage to:English .

to:Rule_EN_02
    a owl:NamedIndividual , to:Rule ;
    rdfs:label "EN Rule 02"@en ;
    to:ruleNumber "2"^^xsd:integer ;
    to:ruleText "Initial consonant clusters (พยัญชนะต้นควบ): bl-, br-, cr-, dr-, fl-, fr-, gl-, gr-, etc. Thai clusters follow IPA. Front-vowel placement (เ แ ไ โ) must precede both consonants."@en ;
    to:appliedToLanguage to:English .

to:Rule_EN_03
    a owl:NamedIndividual , to:Rule ;
    rdfs:label "EN Rule 03"@en ;
    to:ruleNumber "3"^^xsd:integer ;
    to:ruleText "Final consonants (พยัญชนะท้าย): word-final consonants in Thai. Silent final -e and unpronounced finals require consideration."@en ;
    to:appliedToLanguage to:English .

to:Rule_EN_04
    a owl:NamedIndividual , to:Rule ;
    rdfs:label "EN Rule 04"@en ;
    to:ruleNumber "4"^^xsd:integer ;
    to:ruleText "Final consonant clusters (พยัญชนะท้ายควบ): -ft, -lt, -nd, -nk, -mp, -st, -sk, etc. Thai lacks coda clusters; one consonant may require thanthakhat."@en ;
    to:appliedToLanguage to:English .

to:Rule_EN_05
    a owl:NamedIndividual , to:Rule ;
    rdfs:label "EN Rule 05"@en ;
    to:ruleNumber "5"^^xsd:integer ;
    to:ruleText "Silent consonants (พยัญชนะไม่ออกเสียง): consonants present in spelling but absent from IPA are retained in Thai transliteration with thanthakhat."@en ;
    to:appliedToLanguage to:English .

to:Rule_EN_06
    a owl:NamedIndividual , to:Rule ;
    rdfs:label "EN Rule 06"@en ;
    to:ruleNumber "6"^^xsd:integer ;
    to:ruleText "Vowels (สระ): mapping from English vowel phonemes to Thai vowels. IPA /iː/=อี, /ɪ/=อิ, /e/=เอ, /æ/=แ, /ʌ/=อั, /ɑː/=อา, /ɒ/=ออ, /ɔː/=ออ, /ʊ/=อุ, /uː/=อู."@en ;
    to:appliedToLanguage to:English .

to:Rule_EN_07
    a owl:NamedIndividual , to:Rule ;
    rdfs:label "EN Rule 07"@en ;
    to:ruleNumber "7"^^xsd:integer ;
    to:ruleText "Diphthong /juː/ (เสียง /juː/): rendered as อิว in Thai when preceded by consonant. Standalone: ยู."@en ;
    to:appliedToLanguage to:English .

to:Rule_EN_08
    a owl:NamedIndividual , to:Rule ;
    rdfs:label "EN Rule 08"@en ;
    to:ruleNumber "8"^^xsd:integer ;
    to:ruleText "Schwa and mid-central vowels (สระ /ə/, /ɜː/): /ə/=เออ (unstressed), /ɜː/=เออ (stressed mid-central). Multiple Thai spellings for เออ pattern."@en ;
    to:appliedToLanguage to:English .

to:Rule_EN_09
    a owl:NamedIndividual , to:Rule ;
    rdfs:label "EN Rule 09"@en ;
    to:ruleNumber "9"^^xsd:integer ;
    to:ruleText "Diphthongs (สระประสม): /eɪ/=เอ, /aɪ/=ไอ or อาย, /ɔɪ/=ออย, /aʊ/=อาว, /əʊ/=โอ."@en ;
    to:appliedToLanguage to:English .

to:Rule_EN_10
    a owl:NamedIndividual , to:Rule ;
    rdfs:label "EN Rule 10"@en ;
    to:ruleNumber "10"^^xsd:integer ;
    to:ruleText "Centering diphthongs (สระเอีย, แอ, อัว): /ɪə/=เอีย, /eə/=แอ, /ʊə/=อัว."@en ;
    to:appliedToLanguage to:English .

to:Rule_EN_11
    a owl:NamedIndividual , to:Rule ;
    rdfs:label "EN Rule 11"@en ;
    to:ruleNumber "11"^^xsd:integer ;
    to:ruleText "Thai orthographic conventions (การสะกดตามอักขรวิธีไทย): consonant doubling at syllable boundary, thanthakhat placement, mai taikhu for short vowels."@en ;
    to:appliedToLanguage to:English .

to:Rule_EN_12
    a owl:NamedIndividual , to:Rule ;
    rdfs:label "EN Rule 12"@en ;
    to:ruleNumber "12"^^xsd:integer ;
    to:ruleText "Abbreviations (คำย่อ): acronyms read letter-by-letter; initialisms (ASEAN, OPEC) read as words when established."@en ;
    to:appliedToLanguage to:English .

# ============================================================
# English RuleAmbiguities (key cross-cutting issues)
# ============================================================

to:Ambiguity_EN_01
    a owl:NamedIndividual , to:RuleAmbiguity ;
    rdfs:label "Ambiguity EN 01"@en ;
    to:ambiguityDescription "Multiple valid Thai renderings for same IPA phoneme. English /k/ → ค (rule-based) or ก (conventional). Affects: copy, karat, khaki, carat, card, casino. Committee prefers conventional (นิยม) forms for established words."@en ;
    to:hasAmbiguity to:Rule_EN_01 .

to:Ambiguity_EN_05
    a owl:NamedIndividual , to:RuleAmbiguity ;
    rdfs:label "Ambiguity EN 05"@en ;
    to:ambiguityDescription "Silent consonant retention policy. Phonemically absent consonants (bomb→บอมบ์, walk→วอล์ก, column→คอลัมน์) must be retained with thanthakhat in conventional usage but are dropped by IPA-based systems."@en ;
    to:hasAmbiguity to:Rule_EN_05 .

to:Ambiguity_EN_09
    a owl:NamedIndividual , to:RuleAmbiguity ;
    rdfs:label "Ambiguity EN 09"@en ;
    to:ambiguityDescription "Diphthong /aɪ/ realized as สระไอ (ไ-) or อา+ย depending on context. line→ไลน์ (preferred) vs ลายน์ (system). style→สไตล์ (preferred) vs สตายล์ (system). No rule distinguishes them automatically."@en ;
    to:hasAmbiguity to:Rule_EN_09 .

to:Ambiguity_EN_11
    a owl:NamedIndividual , to:RuleAmbiguity ;
    rdfs:label "Ambiguity EN 11"@en ;
    to:ambiguityDescription "Short vowel glyph (ไม้ไต่คู้) usage is convention-based. lock→ล็อก (conventional) vs ลอก (system). bed→เบด (conventional) vs เบ็ด (system). Cannot be determined from IPA alone."@en ;
    to:hasAmbiguity to:Rule_EN_11 .

# ============================================================
# Expert Decisions (EN)
# ============================================================

to:Decision_EN_01_k
    a owl:NamedIndividual , to:ExpertDecision ;
    rdfs:label "Decision EN 01 k"@en ;
    to:decisionJustification "For /k/ initial: rule-based system uses ค, but established conventional words use ก (copy→ก๊อบปี้, karat→กะรัต). System must use lexicon lookup for conventional forms; rule alone is insufficient."@en ;
    to:madeByExpert to:Expert_NECTEC_EN .

to:Decision_EN_05_silent
    a owl:NamedIndividual , to:ExpertDecision ;
    rdfs:label "Decision EN 05 silent"@en ;
    to:decisionJustification "Silent consonants are retained in conventional Thai transliteration to preserve English source spelling. bomb→บอมบ์, walk→วอล์ก, column→คอลัมน์. IPA-based systems cannot reproduce these without a pronunciation-to-spelling reverse lookup."@en ;
    to:madeByExpert to:Expert_NECTEC_EN .

to:Decision_EN_09_diphthong
    a owl:NamedIndividual , to:ExpertDecision ;
    rdfs:label "Decision EN 09 diphthong"@en ;
    to:decisionJustification "/aɪ/ renders as สระไอ when no following consonant (spy→สปาย) or before certain consonants (style→สไตล์). Both patterns are valid; conventional usage takes precedence over pure phoneme mapping."@en ;
    to:madeByExpert to:Expert_NECTEC_EN .

to:Decision_EN_11_maitaikhu
    a owl:NamedIndividual , to:ExpertDecision ;
    rdfs:label "Decision EN 11 maitaikhu"@en ;
    to:decisionJustification "ไม้ไต่คู้ is used when Thai transliteration might be confused with existing Thai words or when context demands disambiguation (lock→ล็อก, impact→อิมแพ็กต์). Rule-based systems lack this contextual knowledge."@en ;
    to:madeByExpert to:Expert_NECTEC_EN .

to:Ambiguity_EN_01
    to:justifiedByDecision to:Decision_EN_01_k .

to:Ambiguity_EN_05
    to:justifiedByDecision to:Decision_EN_05_silent .

to:Ambiguity_EN_09
    to:justifiedByDecision to:Decision_EN_09_diphthong .

to:Ambiguity_EN_11
    to:justifiedByDecision to:Decision_EN_11_maitaikhu .

# ============================================================
# Evaluation Result (NECTEC benchmark, 2026)
# ============================================================

to:EvalResult_EN_2026
    a owl:NamedIndividual , to:EvaluationResult ;
    rdfs:label "NECTEC EN System Evaluation 2026"@en ;
    to:accuracyScore "0.6748"^^xsd:decimal ;
    rdfs:comment "Word-level accuracy 67.48% (220/326 items). NECTEC automatic transliteration system tested against Royal Society benchmark. British English IPA reference: Cambridge Dictionary."@en .

