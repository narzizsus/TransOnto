<https://w3id.org/transonto/kg/de> a owl:Ontology ;
    dcterms:description "German transliteration knowledge graph with 180 lexical entries, benchmark items, gold labels, and expert decisions."@en ;
    dcterms:title "RoyalSocietyTransKG — German"@en ;
    owl:imports <https://w3id.org/transonto/1.0> ;
    owl:versionInfo "1.0" .

<https://w3id.org/transonto/kg/en> a owl:Ontology ;
    dcterms:description "English transliteration benchmark KG with 297 lexical entries, gold labels, and system evaluation. Based on NECTEC benchmark, British English IPA from Cambridge Dictionary."@en ;
    dcterms:title "RoyalSocietyTransKG — English"@en ;
    owl:imports <https://w3id.org/transonto/1.0> ;
    owl:versionInfo "1.0" .

<https://w3id.org/transonto/kg/fr> a owl:Ontology ;
    dcterms:description "French transliteration knowledge graph with 92 lexical entries, benchmark items, gold labels, and expert decisions. Based on Le Petit Robert, 2006."@en ;
    dcterms:title "RoyalSocietyTransKG — French"@en ;
    owl:imports <https://w3id.org/transonto/1.0> ;
    owl:versionInfo "1.0" .

to:Ambiguity_DE_17 to:justifiedByDecision to:Decision_DE_17_Rad .

to:Rule_EN_12 a owl:NamedIndividual,
        to:Rule ;
    rdfs:label "EN Rule 12"@en ;
    to:appliedToLanguage to:English ;
    to:ruleNumber 12 ;
    to:ruleText "Abbreviations (คำย่อ): acronyms read letter-by-letter; initialisms (ASEAN, OPEC) read as words when established."@en .

to:Expert_RoyalSociety_FR a owl:NamedIndividual,
        to:Expert ;
    rdfs:label "Royal Society of Thailand — French Committee"@en,
        "คณะกรรมการทับศัพท์ภาษาฝรั่งเศส ราชบัณฑิตยสภา"@th ;
    dcterms:description "Expert committee responsible for adjudicating French transliteration decisions based on Le Petit Robert, 2006."@en .

to:Ambiguity_DE_25 to:justifiedByDecision to:Decision_DE_25_loanword .

to:Ambiguity_DE_27 to:justifiedByDecision to:Decision_DE_27_von .

to:Ambiguity_EN_09 a owl:NamedIndividual,
        to:RuleAmbiguity ;
    rdfs:label "Ambiguity EN 09"@en ;
    to:ambiguityDescription "Diphthong /aɪ/ realized as สระไอ (ไ-) or อา+ย depending on context. line→ไลน์ (preferred) vs ลายน์ (system). style→สไตล์ (preferred) vs สตายล์ (system). No rule distinguishes them automatically."@en ;
    to:hasAmbiguity to:Rule_EN_09 ;
    to:justifiedByDecision to:Decision_EN_09_diphthong .

to:Ambiguity_FR_03 a owl:NamedIndividual,
        to:RuleAmbiguity ;
    rdfs:label "Ambiguity FR 03"@en ;
    to:ambiguityDescription "Nasal consonant ambiguity in French proper nouns. Words like Napoléon and champagne have phonological nasality that maps to Thai ง. Committee has not finalized nasal mapping for all environments."@en ;
    to:hasAmbiguity to:RuleAddition_FR_03 ;
    to:justifiedByDecision to:Decision_FR_03_nasal .

to:Ambiguity_FR_09 a owl:NamedIndividual,
        to:RuleAmbiguity ;
    rdfs:label "Ambiguity FR 09"@en ;
    to:ambiguityDescription "Semi-vowel yod [j] and consonant reduction cluster patterns. fouine [fwinɛ/fwin] shows optional schwa deletion. Yod-initial clusters before nasal vowels remain under review."@en ;
    to:hasAmbiguity to:RuleAddition_FR_09 ;
    to:justifiedByDecision to:Decision_FR_09_yod .

to:Expert_NECTEC_EN a owl:NamedIndividual,
        to:Expert ;
    rdfs:label "NECTEC Natural Language Processing Team"@en,
        "ทีมวิจัยเทคโนโลยีภาษาธรรมชาติและความหมาย ศูนย์เทคโนโลยีอิเล็กทรอนิกส์และคอมพิวเตอร์แห่งชาติ"@th ;
    dcterms:description "NECTEC research team responsible for developing the English transliteration system and benchmark evaluation (Report 3, April 2026)."@en .

to:Expert_RoyalSociety_DE a owl:NamedIndividual,
        to:Expert ;
    rdfs:label "Royal Society of Thailand — German Committee"@en,
        "คณะกรรมการทับศัพท์ภาษาเยอรมัน ราชบัณฑิตยสภา"@th ;
    dcterms:description "Expert committee responsible for adjudicating German transliteration decisions."@en .

to:RuleAddition_FR_07 a owl:NamedIndividual,
        to:RuleAddition ;
    rdfs:label "FR Addition 7"@en ;
    to:additionNumber 7 ;
    to:appliedToLanguage to:French ;
    to:ruleText "Mute-e in medial syllable causes consonant cluster in Thai. When e caduc (schwa) is deleted, preceding consonants form a cluster. chopper [ʃɔpe]→ชอปเป shows retention of unstressed syllable."@en .

to:RuleAddition_FR_13 a owl:NamedIndividual,
        to:RuleAddition ;
    rdfs:label "FR Addition 13"@en ;
    to:additionNumber 13 ;
    to:appliedToLanguage to:French ;
    to:ruleText "H mute vs h aspiré distinction. H muet allows liaison and elision (les hommes→lezɔm). H aspiré blocks liaison (le haricot→lə'aʀiko). Committee marks h aspiré entries explicitly."@en .

to:Ambiguity_DE_21 to:justifiedByDecision to:Decision_DE_21_final_r .

to:Ambiguity_FR_13 a owl:NamedIndividual,
        to:RuleAmbiguity ;
    rdfs:label "Ambiguity FR 13"@en ;
    to:ambiguityDescription "H mute vs h aspiré distinction. Phonetically identical word-initial h, but liaison/elision behavior differs. le haricot [lə'aʀiko] vs les hommes [lezɔm] requires lexical lookup."@en ;
    to:hasAmbiguity to:RuleAddition_FR_13 ;
    to:justifiedByDecision to:Decision_FR_13_h .

to:RuleAddition_FR_05 a owl:NamedIndividual,
        to:RuleAddition ;
    rdfs:label "FR Addition 5"@en ;
    to:additionNumber 5 ;
    to:appliedToLanguage to:French ;
    to:ruleText "Final consonants p, t, k, s, f are generally silent in French word-final position and not represented in Thai transliteration unless followed by a vowel-initial word (liaison). aide→เอด: final -e is silent; haute→โอต: final position."@en .

to:RuleAddition_FR_10 a owl:NamedIndividual,
        to:RuleAddition ;
    rdfs:label "FR Addition 10"@en ;
    to:additionNumber 10 ;
    to:appliedToLanguage to:French ;
    to:ruleText "Nasal vowels (voyelles nasales). French nasal vowels have no exact Thai equivalent. 10.1: ɛ̃/œ̃→แ_ง; 10.2: ɔ̃→อ็อง, ɑ̃→อ็อง; brun pattern maps [œ̃]→อ็อง."@en .

to:Rule_EN_07 a owl:NamedIndividual,
        to:Rule ;
    rdfs:label "EN Rule 07"@en ;
    to:appliedToLanguage to:English ;
    to:ruleNumber 7 ;
    to:ruleText "Diphthong /juː/ (เสียง /juː/): rendered as อิว in Thai when preceded by consonant. Standalone: ยู."@en .

to:Ambiguity_EN_11 a owl:NamedIndividual,
        to:RuleAmbiguity ;
    rdfs:label "Ambiguity EN 11"@en ;
    to:ambiguityDescription "Short vowel glyph (ไม้ไต่คู้) usage is convention-based. lock→ล็อก (conventional) vs ลอก (system). bed→เบด (conventional) vs เบ็ด (system). Cannot be determined from IPA alone."@en ;
    to:hasAmbiguity to:Rule_EN_11 ;
    to:justifiedByDecision to:Decision_EN_11_maitaikhu .

to:RuleAddition_FR_08 a owl:NamedIndividual,
        to:RuleAddition ;
    rdfs:label "FR Addition 8"@en ;
    to:additionNumber 8 ;
    to:appliedToLanguage to:French ;
    to:ruleText "Stop consonant clusters pr-, tr-, kr- at word onset. French initial stop+liquid clusters are rendered as Thai consonant clusters or split syllables. 8.1: pr-; 8.2: tr-; 8.3: cr-/kr-."@en .

to:Rule_EN_11 a owl:NamedIndividual,
        to:Rule ;
    rdfs:label "EN Rule 11"@en ;
    to:appliedToLanguage to:English ;
    to:ruleNumber 11 ;
    to:ruleText "Thai orthographic conventions (การสะกดตามอักขรวิธีไทย): consonant doubling at syllable boundary, thanthakhat placement, mai taikhu for short vowels."@en .

to:Rule_EN_10 a owl:NamedIndividual,
        to:Rule ;
    rdfs:label "EN Rule 10"@en ;
    to:appliedToLanguage to:English ;
    to:ruleNumber 10 ;
    to:ruleText "Centering diphthongs (สระเอีย, แอ, อัว): /ɪə/=เอีย, /eə/=แอ, /ʊə/=อัว."@en .

to:RuleAddition_FR_06 a owl:NamedIndividual,
        to:RuleAddition ;
    rdfs:label "FR Addition 6"@en ;
    to:additionNumber 6 ;
    to:appliedToLanguage to:French ;
    to:ruleText "Final consonants b, d, g, z, v, ʒ, l, ʀ, m, n followed by a pause are deleted or reduced. Word-final silent consonant deletion. Applies to common words like chat [ʃa]→ชา, beau [bo]→โบ."@en .

to:RuleAddition_FR_01 a owl:NamedIndividual,
        to:RuleAddition ;
    rdfs:label "FR Addition 1"@en ;
    to:additionNumber 1 ;
    to:appliedToLanguage to:French ;
    to:ruleText "Pronunciation follows standard French (Standard français/Hochfranzösisch). IPA sourced from Le Petit Robert, Dictionnaire de la langue française, 2006. Vowel phoneme [ʃ] → ช, [ʀ] → ร, [ɲ] → น, [y] → ว, [ø]/[ɶ] → เออ."@en .

to:Ambiguity_EN_01 a owl:NamedIndividual,
        to:RuleAmbiguity ;
    rdfs:label "Ambiguity EN 01"@en ;
    to:ambiguityDescription "Multiple valid Thai renderings for same IPA phoneme. English /k/ → ค (rule-based) or ก (conventional). Affects: copy, karat, khaki, carat, card, casino. Committee prefers conventional (นิยม) forms for established words."@en ;
    to:hasAmbiguity to:Rule_EN_01 ;
    to:justifiedByDecision to:Decision_EN_01_k .

to:RuleAddition_FR_14 a owl:NamedIndividual,
        to:RuleAddition ;
    rdfs:label "FR Addition 14"@en ;
    to:additionNumber 14 ;
    to:appliedToLanguage to:French ;
    to:ruleText "Liaison rules. Final consonants normally silent become pronounced when followed by a vowel-initial word. Liaison consonants: s/x→[z], d→[t], t→[t], n→[n], f→[v], r→[r]. Fixed expressions (groupes figés) always apply liaison."@en .

to:RuleAddition_FR_09 a owl:NamedIndividual,
        to:RuleAddition ;
    rdfs:label "FR Addition 9"@en ;
    to:additionNumber 9 ;
    to:appliedToLanguage to:French ;
    to:ruleText "Consonant reduction in complex codas and specific clusters. Semi-vowel [j] (yod) from ill/y sequences; lateral clusters; r-consonant patterns. 9.1: yod; 9.2: ill→j/i; 9.3: C+r final; 9.4: r+coda; 9.5: s/x+r."@en .

to:Rule_EN_08 a owl:NamedIndividual,
        to:Rule ;
    rdfs:label "EN Rule 08"@en ;
    to:appliedToLanguage to:English ;
    to:ruleNumber 8 ;
    to:ruleText "Schwa and mid-central vowels (สระ /ə/, /ɜː/): /ə/=เออ (unstressed), /ɜː/=เออ (stressed mid-central). Multiple Thai spellings for เออ pattern."@en .

to:RuleAddition_FR_11 a owl:NamedIndividual,
        to:RuleAddition ;
    rdfs:label "FR Addition 11"@en ;
    to:additionNumber 11 ;
    to:appliedToLanguage to:French ;
    to:ruleText "Proper nouns follow their phonological pattern. Famous persons use IPA directly. Compound and hyphenated names retain structure with hyphens. Titles (de, le, la) follow liaison rules."@en .

to:Rule_EN_04 a owl:NamedIndividual,
        to:Rule ;
    rdfs:label "EN Rule 04"@en ;
    to:appliedToLanguage to:English ;
    to:ruleNumber 4 ;
    to:ruleText "Final consonant clusters (พยัญชนะท้ายควบ): -ft, -lt, -nd, -nk, -mp, -st, -sk, etc. Thai lacks coda clusters; one consonant may require thanthakhat."@en .

to:Rule_EN_09 a owl:NamedIndividual,
        to:Rule ;
    rdfs:label "EN Rule 09"@en ;
    to:appliedToLanguage to:English ;
    to:ruleNumber 9 ;
    to:ruleText "Diphthongs (สระประสม): /eɪ/=เอ, /aɪ/=ไอ or อาย, /ɔɪ/=ออย, /aʊ/=อาว, /əʊ/=โอ."@en .

to:Rule_EN_05 a owl:NamedIndividual,
        to:Rule ;
    rdfs:label "EN Rule 05"@en ;
    to:appliedToLanguage to:English ;
    to:ruleNumber 5 ;
    to:ruleText "Silent consonants (พยัญชนะไม่ออกเสียง): consonants present in spelling but absent from IPA are retained in Thai transliteration with thanthakhat."@en .

to:Rule_EN_02 a owl:NamedIndividual,
        to:Rule ;
    rdfs:label "EN Rule 02"@en ;
    to:appliedToLanguage to:English ;
    to:ruleNumber 2 ;
    to:ruleText "Initial consonant clusters (พยัญชนะต้นควบ): bl-, br-, cr-, dr-, fl-, fr-, gl-, gr-, etc. Thai clusters follow IPA. Front-vowel placement (เ แ ไ โ) must precede both consonants."@en .

to:Rule_EN_01 a owl:NamedIndividual,
        to:Rule ;
    rdfs:label "EN Rule 01"@en ;
    to:appliedToLanguage to:English ;
    to:ruleNumber 1 ;
    to:ruleText "Initial consonants (พยัญชนะต้น): single initial consonants mapped to Thai by IPA. Multiple Thai options exist for same IPA (e.g., /k/ → ค or ก)."@en .

to:Rule_EN_06 a owl:NamedIndividual,
        to:Rule ;
    rdfs:label "EN Rule 06"@en ;
    to:appliedToLanguage to:English ;
    to:ruleNumber 6 ;
    to:ruleText "Vowels (สระ): mapping from English vowel phonemes to Thai vowels. IPA /iː/=อี, /ɪ/=อิ, /e/=เอ, /æ/=แ, /ʌ/=อั, /ɑː/=อา, /ɒ/=ออ, /ɔː/=ออ, /ʊ/=อุ, /uː/=อู."@en .

to:Rule_EN_03 a owl:NamedIndividual,
        to:Rule ;
    rdfs:label "EN Rule 03"@en ;
    to:appliedToLanguage to:English ;
    to:ruleNumber 3 ;
    to:ruleText "Final consonants (พยัญชนะท้าย): word-final consonants in Thai. Silent final -e and unpronounced finals require consideration."@en .

to:EvalResult_EN_2026 a owl:NamedIndividual,
        to:EvaluationResult ;
    rdfs:label "NECTEC EN System Evaluation 2026"@en ;
    rdfs:comment "Word-level accuracy 67.48% (220/326 items). NECTEC automatic transliteration system tested against Royal Society benchmark. British English IPA reference: Cambridge Dictionary."@en ;
    to:accuracyScore 0.6748 .

