to:Ambiguity_EN_05 a owl:NamedIndividual,
        to:RuleAmbiguity ;
    rdfs:label "Ambiguity EN 05"@en ;
    to:ambiguityDescription "Silent consonant retention policy. Phonemically absent consonants (bomb→บอมบ์, walk→วอล์ก, column→คอลัมน์) must be retained with thanthakhat in conventional usage but are dropped by IPA-based systems."@en ;
    to:hasAmbiguity to:Rule_EN_05 ;
    to:justifiedByDecision to:Decision_EN_05_silent .

